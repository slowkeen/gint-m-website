{
   "action": {
      "default_icon": {
         "16": "assets/icon16.png",
         "24": "assets/icon48.png",
         "32": "assets/icon128.png"
      },
      "default_popup": "popup.html",
      "default_title": "YoutubeTracker"
   },
   "author": "Rakambda",
   "background": {
      "service_worker": "service_worker.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "lib/jquery/jquery.min.js", "js/YTTUtils.js", "js/content.js" ],
      "matches": [ "https://youtube.com/*", "https://www.youtube.com/*", "https://music.youtube.com/*", "https://youtube-nocookie.com/*", "https://www.youtube-nocookie.com/*" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": {
      "object-src": "self",
      "script-src": "self"
   },
   "description": "This extension will track your time on YouTube",
   "homepage_url": "https://github.com/Rakambda/YTTracker",
   "host_permissions": [ "https://youtube.com/*", "https://www.youtube.com/*", "https://music.youtube.com/*", "https://youtube-nocookie.com/*", "https://www.youtube-nocookie.com/*", "https://yttracker.rakambda.fr/*" ],
   "icons": {
      "128": "assets/icon128.png",
      "16": "assets/icon16.png",
      "48": "assets/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "YouTube Tracker",
   "optional_permissions": [ "notifications" ],
   "options_page": "options.html",
   "permissions": [ "storage", "unlimitedStorage", "identity", "downloads" ],
   "short_name": "YTTracker",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "3.1.3",
   "web_accessible_resources": [ {
      "matches": [ "https://youtube.com/*", "https://www.youtube.com/*", "https://music.youtube.com/*", "https://youtube-nocookie.com/*", "https://www.youtube-nocookie.com/*" ],
      "resources": [ "js/YTTUtils.js", "js/hookerUtils.js", "js/hooker.js" ]
   } ]
}
