{
   "action": {
      "default_icon": {
         "128": "icons/icon-128.png",
         "16": "icons/icon-16.png",
         "32": "icons/icon-32.png",
         "48": "icons/icon-48.png"
      },
      "default_title": "Fonts Ninja"
   },
   "author": "Fonts Ninja",
   "background": {
      "service_worker": "background.bundle.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "contentScript.bundle.js" ],
      "matches": [ "http://*/*", "https://*/*" ]
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'",
      "sandbox": "sandbox allow-scripts; script-src 'self' ; object-src 'self'"
   },
   "description": "Speed up your design workflow!",
   "homepage_url": "https://www.fonts.ninja",
   "host_permissions": [ "http://*/*", "https://*/*" ],
   "icons": {
      "128": "icons/icon-128.png",
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Fonts Ninja",
   "permissions": [ "activeTab", "tabs", "storage", "scripting" ],
   "short_name": "Fonts Ninja",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "8.0.4",
   "web_accessible_resources": [ {
      "matches": [ "http://*/*", "https://*/*" ],
      "resources": [ "extension.bundle.js", "frame.html", "icons/*", "img/*", "fonts-ninja-helpers/*", "*.woff", "*.woff2" ]
   } ]
}
